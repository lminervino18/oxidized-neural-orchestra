{
  "model_defs": {
    "dense_small": {
      "type": "dense",
      "dense": [
        {"size": 128, "act": "sigmoid"},
        {"size": 64,  "act": "sigmoid"},
        {"size": 10,  "act": "sigmoid"}
      ]
    },
    "dense_large": {
      "type": "dense",
      "dense": [
        {"size": 256, "act": "sigmoid"},
        {"size": 128, "act": "sigmoid"},
        {"size": 64,  "act": "sigmoid"},
        {"size": 10,  "act": "sigmoid"}
      ]
    },
    "conv_tiny": {
      "type": "conv",
      "conv": [{"input_dim": [1,28,28], "kernel_dim": [8,1,4], "stride": 2, "padding": 0, "act": null}],
      "dense": [{"size": 10, "act": "sigmoid"}],
      "flat_size": 1352
    },
    "conv_small": {
      "type": "conv",
      "conv": [{"input_dim": [1,28,28], "kernel_dim": [16,1,4], "stride": 2, "padding": 0, "act": "sigmoid"}],
