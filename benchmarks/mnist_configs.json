      "flat_size": 2704
    },
    "conv_large": {
      "type": "conv",
      "conv": [{"input_dim": [1,28,28], "kernel_dim": [32,1,4], "stride": 2, "padding": 0, "act": "sigmoid"}],
      "dense": [{"size": 128, "act": "sigmoid"}, {"size": 64, "act": "sigmoid"}, {"size": 10, "act": "sigmoid"}],
      "flat_size": 5408
    },
    "conv_tiny_softmax": {
      "type": "conv",
      "conv": [{"input_dim": [1,28,28], "kernel_dim": [8,1,4], "stride": 2, "padding": 0, "act": null}],
      "dense": [{"size": 10, "act": "softmax"}],
      "flat_size": 1352
    }
  },

